meta {
  name: 6. GET escrow transactions - as buyer (owner) - expect 200
  type: http
  seq: 6
}

get {
  url: {{base_url}}/api/v1/escrows/{{escrow_id}}/transactions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{buyer_token}}
}

tests {
  test("should return 200 for the contract's own buyer", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("data should be an array", function() {
    expect(res.getBody().data).to.be.an('array');
  });
}
