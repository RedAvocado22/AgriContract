meta {
  name: 18. Verify contract ACTIVE (after escrow.locked)
  type: http
  seq: 18
}

get {
  url: {{base_url}}/api/v1/contracts/{{contract_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{buyer_token}}
}

tests {
  test("should return 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("status should be ACTIVE", function() {
    expect(res.getBody().data.status).to.equal("ACTIVE");
  });
}
