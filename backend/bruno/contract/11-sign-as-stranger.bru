meta {
  name: 11. [Security] Sign as stranger (expect 403)
  type: http
  seq: 11
}

put {
  url: {{base_url}}/api/v1/contracts/{{contract_id}}/sign
  body: none
  auth: bearer
}

auth:bearer {
  token: {{stranger_token}}
}

tests {
  test("stranger sign should return 403", function() {
    expect(res.getStatus()).to.equal(403);
  });
}
