meta {
  name: GET /api/v1/contracts (protected, with token)
  type: http
  seq: 4
}

get {
  url: {{base_url}}/api/v1/contracts
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("should not return 401 with valid token", function() {
    expect(res.getStatus()).to.not.equal(401);
  });
}
