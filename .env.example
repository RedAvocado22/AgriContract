# Database
DB_ROOT_PASSWORD=password
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_JWK_URI=http://keycloak:8080/realms/agricontract/protocol/openid-connect/certs

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Internal trust — Gateway <-> downstream services (generate: openssl rand -hex 32 — do NOT use a literal/example value)
GATEWAY_INTERNAL_SECRET=REPLACE_WITH_RANDOM_SECRET
# Internal trust — service <-> service (Feign) (generate: openssl rand -hex 32 — do NOT use a literal/example value)
SERVICE_INTERNAL_SECRET=REPLACE_WITH_RANDOM_SECRET

# Mail (MailHog for dev)
MAIL_HOST=mailhog
MAIL_PORT=1025
