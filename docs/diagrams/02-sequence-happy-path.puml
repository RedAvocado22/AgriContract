@startuml Phase 1 Happy Path
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

title Phase 1 Happy Path\nOFFERED → NEGOTIATING → SIGNED → ACTIVE → DELIVERED → SETTLED

actor Seller
actor Buyer
participant "API Gateway" as GW
participant "product-service" as PS
participant "contract-service" as CS
database "contract_db\n+ negotiations + outbox" as CDB
queue "RabbitMQ" as MQ
participant "escrow-service" as ES
database "escrow_db\n+ ledger + outbox" as EDB
participant "notification-service" as NS

== 1. Marketplace ==
Seller -> GW : POST /api/v1/products
GW -> PS : trusted user headers
PS --> Seller : 201 product
Seller -> GW : POST /api/v1/listings
GW -> PS : trusted user headers
PS -> PS : Listing ACTIVE\nSnapshot name + cover image
PS --> Seller : 201 listing

== 2. Offer and negotiation ==
Buyer -> GW : POST /api/v1/contracts\n{contractId?, listingId, terms}
GW -> CS : buyer principal
CS -> PS : GET listing snapshot [Feign]
CS -> CS : Contract.offer() → OFFERED\ntermsRevision = 1
CS -> CDB : save contract + revision 1 + outbox
CS --> Buyer : 201 contract

Seller -> GW : PUT /api/v1/contracts/{id}/negotiate\n{newTerms}
GW -> CS : seller principal
CS -> CS : counterOffer() → NEGOTIATING\nrevision++ · clear signatories
CS -> CDB : update contract + append revision + outbox
CS --> Seller : 200

== 3. Both parties sign the same revision ==
Seller -> GW : PUT /api/v1/contracts/{id}/sign
GW -> CS : seller principal
CS -> CS : add seller signature\ncontract remains NEGOTIATING
CS -> CDB : save + contract.partially_signed outbox

Buyer -> GW : PUT /api/v1/contracts/{id}/sign
GW -> CS : buyer principal
CS -> CS : both signatures → SIGNED
CS -> PS : PUT /api/v1/listings/{id}/close [Feign]
PS -> PS : ACTIVE → CLOSED
CS -> CDB : save + contract.signed outbox
CS --> Buyer : 200

CDB -> MQ : Outbox poller publishes contract.signed

== 4. Two-party escrow lock ==
MQ -> ES : contract.signed
ES -> ES : unique contractId\nlock buyer payment → BUYER_LOCKED
ES -> EDB : save account + LOCK ledger + outbox

Seller -> GW : PUT /api/v1/escrows/{contractId}/confirm-deposit
GW -> ES : SELLER principal
ES -> ES : sellerDeposit = total × rate\nBUYER_LOCKED → FULLY_LOCKED
ES -> EDB : save LOCK ledger + escrow.locked outbox
EDB -> MQ : Outbox poller publishes escrow.locked
MQ -> CS : escrow.locked
CS -> CS : activate() → ACTIVE
CS -> CDB : save + contract.activated outbox
MQ -> NS : escrow.locked
NS -> NS : email Seller

== 5. Delivery confirmation and dispute window ==
Buyer -> GW : PUT /api/v1/contracts/{id}/confirm-delivery
GW -> CS : BUYER principal
CS -> CS : ACTIVE → DELIVERED
CS -> CDB : save + contract.delivered outbox
CDB -> MQ : publish contract.delivered
MQ -> ES : contract.delivered
ES -> ES : FULLY_LOCKED → DELIVERY_PENDING\nreleaseEligibleAt = now + PT30S
ES -> EDB : save deadline
MQ -> NS : contract.delivered
NS -> NS : email Seller

== 6. Automatic release after no dispute ==
... configured dispute window expires ...
ES -> EDB : scheduler finds due DELIVERY_PENDING account
ES -> ES : RELEASED\nRELEASE buyer payment\nREFUND seller deposit
ES -> EDB : append ledger + escrow.released outbox
EDB -> MQ : publish escrow.released
MQ -> CS : escrow.released
CS -> CS : DELIVERED → SETTLED
CS -> CDB : save + contract.settled outbox
MQ -> NS : escrow.released
NS -> NS : email Buyer + Seller

@enduml
