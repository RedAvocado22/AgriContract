@startuml user_db Schema
!theme plain
skinparam backgroundColor #FAFAFA
title user-service — user_db

entity "user_profiles" as UP {
    * id : BIGINT <<PK, AUTO_INCREMENT>>
    --
    * user_id : VARCHAR(255) <<UNIQUE>> (Keycloak sub)
    * organization_name : VARCHAR(255)
    * role : ENUM(SELLER, BUYER, ADMIN)
    * email : VARCHAR(255)
    phone : VARCHAR(50)
    address : TEXT
    * verification_status : ENUM(PENDING, VERIFIED, REJECTED)
    * created_at : DATETIME
    * updated_at : DATETIME
}

note right of UP
  - userId = Keycloak sub
  - KHÔNG lưu password/credentials
  - contactInfo được embed trực tiếp
    (email, phone, address)
end note

@enduml
