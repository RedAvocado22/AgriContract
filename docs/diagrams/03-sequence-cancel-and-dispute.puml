@startuml Phase 1 Cancel and Dispute
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

title Phase 1 Cancel, Dispute & Arbitration

actor Seller
actor Buyer
actor Admin
participant "API Gateway" as GW
participant "contract-service" as CS
database "contract_db + outbox" as CDB
queue "RabbitMQ" as MQ
participant "escrow-service" as ES
database "escrow_db + ledger + outbox" as EDB
participant "notification-service" as NS

== Case A: Buyer cancels while ACTIVE ==
Buyer -> GW : PUT /api/v1/contracts/{id}/cancel\n{reason}
GW -> CS : buyer principal
CS -> CS : ACTIVE → CANCELLED\ncancelledBy = BUYER
CS -> CDB : save + contract.cancelled outbox
CDB -> MQ : publish contract.cancelled
MQ -> ES : cancelledBy=BUYER + buyerPenaltyRate
ES -> ES : FULLY_LOCKED → PENALIZED_BUYER
ES -> EDB : PENALIZE_BUYER\nREFUND_TO_BUYER\nREFUND_TO_SELLER
ES -> EDB : save escrow.penalized/refunded outbox
EDB -> MQ : publish events
MQ -> NS : escrow.penalized
NS -> NS : email penalized Buyer

== Case B: Seller cancels while ACTIVE ==
Seller -> GW : PUT /api/v1/contracts/{id}/cancel\n{reason}
GW -> CS : seller principal
CS -> CS : ACTIVE → CANCELLED\ncancelledBy = SELLER
CS -> CDB : save + contract.cancelled outbox
CDB -> MQ : publish contract.cancelled
MQ -> ES : cancelledBy=SELLER
ES -> ES : FULLY_LOCKED → PENALIZED_SELLER
ES -> EDB : PENALIZE_SELLER deposit to Buyer\nREFUND_TO_BUYER full payment
ES -> EDB : save escrow.penalized/refunded outbox
EDB -> MQ : publish events
MQ -> NS : escrow.penalized
NS -> NS : email penalized Seller

== Case C: Buyer disputes during delivery window ==
note over Buyer, ES
  Precondition:
  Contract DELIVERED
  Escrow DELIVERY_PENDING
  releaseEligibleAt has not been processed
end note

Buyer -> GW : PUT /api/v1/contracts/{id}/dispute\n{reason}
GW -> CS : buyer principal
CS -> CS : DELIVERED → DISPUTED
CS -> CDB : save + contract.disputed outbox
CDB -> MQ : publish contract.disputed
MQ -> ES : contract.disputed
ES -> ES : DELIVERY_PENDING → DISPUTED\nclear releaseEligibleAt
ES -> EDB : save held state [optimistic version]
MQ -> NS : contract.disputed
NS -> NS : email Admin + Buyer + Seller

... release scheduler polls ...
ES -> EDB : DISPUTED is not release eligible

== Admin arbitration ==
Admin -> GW : PUT /api/v1/escrows/{contractId}/arbitrate\n{buyerAmount, sellerAmount, justification}
GW -> ES : ADMIN principal
ES -> ES : require DISPUTED\nrequire buyer + seller = payment + deposit\nrequire non-blank justification
ES -> ES : DISPUTED → ARBITRATED
ES -> EDB : append ARBITRATION_BUYER\n+ ARBITRATION_SELLER\n+ escrow.arbitrated outbox
EDB -> MQ : publish escrow.arbitrated
MQ -> CS : escrow.arbitrated
CS -> CS : DISPUTED → SETTLED
CS -> CDB : save + contract.settled outbox
MQ -> NS : escrow.arbitrated
NS -> NS : email Buyer + Seller\nwith justification

@enduml
