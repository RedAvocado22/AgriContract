@startuml Cancel Flow & Dispute Flow
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial

title Cancel Flow & Dispute Flow\n(chỉ áp dụng từ ACTIVE trở đi — escrow đã LOCKED)

actor Seller
actor Buyer
actor Admin
participant "API Gateway" as GW
participant "contract-service" as CS
database "contract_db" as CDB
participant "Outbox Poller" as OP
queue "RabbitMQ" as MQ
participant "escrow-service" as ES
participant "notification-service" as NS

note over Buyer, ES
  Pre-condition cho tất cả flows dưới:
  Contract đang ACTIVE — Escrow đang LOCKED
  (Cancel trước SIGNED không cần business logic — bỏ qua offer là đủ)
end note

== CASE A: Buyer cancel sau ACTIVE ==

Buyer -> GW : PUT /api/contracts/{id}/cancel\n{reason: "..."}
GW -> CS : forward (X-User-Id: buyerId)
CS -> CS : Contract.cancel(buyerId)\ncancelledBy = BUYER → CANCELLED
CS -> CDB : save + ContractCancelledEvent\n{cancelledBy: "BUYER"} (PENDING)
CS --> Buyer : 200 OK

OP -> MQ : publish contract.cancelled {cancelledBy: BUYER}

MQ -> ES : contract.cancelled
ES -> ES : cancelledBy == BUYER\n→ PENALIZED_BUYER\npenaltyAmount → seller\nphần còn lại refund → buyer
ES -> MQ : publish escrow.penalized {penalizedParty: BUYER}

MQ -> NS : escrow.penalized
NS -> NS : notify both parties
note right of NS : Buyer: "Bạn đã bị phạt {amount}\ndo hủy hợp đồng"

== CASE B: Seller cancel sau ACTIVE ==

Seller -> GW : PUT /api/contracts/{id}/cancel\n{reason: "..."}
GW -> CS : forward (X-User-Id: sellerId)
CS -> CS : Contract.cancel(sellerId)\ncancelledBy = SELLER → CANCELLED
CS -> CDB : save + ContractCancelledEvent\n{cancelledBy: "SELLER"} (PENDING)
CS --> Seller : 200 OK

OP -> MQ : publish contract.cancelled {cancelledBy: SELLER}

MQ -> ES : contract.cancelled
ES -> ES : cancelledBy == SELLER\n→ PENALIZED_SELLER\nFull refund → buyer\nMark seller penalty (Phase 1: log only)
ES -> MQ : publish escrow.penalized {penalizedParty: SELLER}

MQ -> NS : escrow.penalized
NS -> NS : notify both parties
note right of NS : Seller: "Bạn bị phạt do hủy hợp đồng\nBuyer được hoàn tiền đầy đủ"

== CASE C: Buyer dispute sau DELIVERED ==

note over Buyer, ES
  Pre-condition: Contract đang DELIVERED
  Buyer không hài lòng với chất lượng hàng
end note

Buyer -> GW : PUT /api/contracts/{id}/dispute\n{reason: "Hang khong dung chat luong"}
GW -> CS : forward (X-User-Id: buyerId)
CS -> CS : Contract.dispute(buyerId)\nDELIVERED → DISPUTED
CS -> CDB : save + ContractDisputedEvent (PENDING)
CS --> Buyer : 200 OK

OP -> MQ : publish contract.disputed

MQ -> NS : contract.disputed
NS -> NS : notify admin + both parties
note right of NS : "[ADMIN] Tranh chap moi\nContractId: {id}\nCan xu ly"

== Admin phân xử ==

Admin -> GW : PUT /api/escrow/{contractId}/arbitrate\n{buyerAmount: X, sellerAmount: Y}
GW -> ES : forward (X-User-Id: adminId)
ES -> ES : validate buyerAmount + sellerAmount == totalAmount
ES -> ES : ARBITRATED — phan chia theo admin decision
ES -> MQ : publish escrow.penalized\n{penalizedParty: loser, amount: penalty}

MQ -> NS : notify both parties ve ket qua phan xu

@enduml
