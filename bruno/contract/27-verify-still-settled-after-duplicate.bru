meta {
  name: 27. [Edge] Verify still SETTLED after duplicate escrow.released
  type: http
  seq: 27
}

get {
  url: {{base_url}}/api/v1/contracts/{{contract_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{buyer_token}}
}

tests {
  test("should return 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("status should still be SETTLED", function() {
    expect(res.getBody().data.status).to.equal("SETTLED");
  });
}
