meta {
  name: 05. [Security] Bypass gateway — fake X-User-Id without X-Gateway-Secret (expect 401/403)
  type: http
  seq: 5
}

post {
  url: {{contract_service_url}}/api/v1/contracts
  body: json
  auth: none
}

headers {
  X-User-Id: {{buyer1_sub}}
  X-User-Role: BUYER
}

body:json {
  {
    "listingId": "any-listing",
    "terms": {}
  }
}

tests {
  test("forged headers without gateway secret should be rejected", function() {
    expect(res.getStatus()).to.be.oneOf([401, 403]);
  });
}
