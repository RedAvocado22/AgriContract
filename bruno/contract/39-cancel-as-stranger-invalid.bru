meta {
  name: 39. [Security] Cancel as stranger (expect 403) — state: ACTIVE (seed-ctr-active)
  type: http
  seq: 39
}

put {
  url: {{base_url}}/api/v1/contracts/{{cancel_buyer_contract_id}}/cancel
  body: json
  auth: bearer
}

auth:bearer {
  token: {{stranger_token}}
}

body:json {
  {
    "reason": "stranger trying to cancel"
  }
}

tests {
  test("stranger cancel should return 403", function() {
    expect(res.getStatus()).to.equal(403);
  });
}
