meta {
  name: 32. List Contracts (seller, filter by status=ACTIVE)
  type: http
  seq: 32
}

get {
  url: {{base_url}}/api/v1/contracts?role=SELLER&status=ACTIVE&page=0&size=10
  body: none
  auth: bearer
}

auth:bearer {
  token: {{seller_token}}
}

tests {
  test("should return 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("should return paginated response", function() {
    const data = res.getBody().data;
    expect(data).to.have.property("content");
    expect(data).to.have.property("totalElements");
  });
  test("all returned contracts should have status ACTIVE", function() {
    const contracts = res.getBody().data.content;
    contracts.forEach(c => {
      expect(c.status).to.equal("ACTIVE");
    });
  });
  test("should have at least one contract", function() {
    expect(res.getBody().data.totalElements).to.be.above(0);
  });
}
